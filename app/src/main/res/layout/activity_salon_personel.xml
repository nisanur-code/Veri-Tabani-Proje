<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mekan ve Personel Kayıt Paneli"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:textColor="#004D40"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yeni Salon/Derslik Tanımla"
            android:textStyle="bold"
            android:textColor="#00796B"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etSalonAdi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Salon Adı (Örn: Z-04, D-101)"
            android:background="@android:drawable/editbox_background"/>

        <EditText
            android:id="@+id/etKapasite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Öğrenci Kapasitesi (Örn: 70)"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"/>

        <EditText
            android:id="@+id/etKatBilgisi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Kat Numarası (Örn: 0, 1, 2)"
            android:inputType="number"
            android:layout_marginBottom="12dp"
            android:background="@android:drawable/editbox_background"/>

        <Button
            android:id="@+id/btnSalonKaydet"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Salonu Veritabanına İşle"
            android:backgroundTint="#009688"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#B2DFDB"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yeni Gözetmen/Personel Tanımla"
            android:textStyle="bold"
            android:textColor="#004D40"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etPersonelAdi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Personel Adı Soyadı (Ünvan ile)"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnPersonelKaydet"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Personeli Sisteme Kaydet"
            android:backgroundTint="#00796B"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kayıtlı Salon ve Personeller"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/txtSalonListesi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Veriler SQL'den yükleniyor..."
            android:textColor="#555555"
            android:padding="10dp"
            android:background="#E0F2F1"/>

    </LinearLayout>
</ScrollView>