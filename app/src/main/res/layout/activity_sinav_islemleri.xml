<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F0F4C3"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Sınav ve Oturum Yönetimi"
    android:textSize="22sp"
    android:textStyle="bold"
    android:textColor="#33691E"
    android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dönem/Yıl Seçimi"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/etDonem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Örn: 2025-2026 Bahar"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Oturum Saati"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/etOturumSaati"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Örn: 10:30"
        android:inputType="time"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnTakvimOlustur"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Sınav Takvimine Ekle"
        android:backgroundTint="#558B2F"
        android:textColor="#FFFFFF"/>

</LinearLayout>