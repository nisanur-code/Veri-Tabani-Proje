<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Personel ve Mazeret Yönetimi"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Personel (Gözetmen) Seçin:" />
    <Spinner
        android:id="@+id/spnPersonel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="15dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mazeretli Olduğu Gün:" />
    <EditText
        android:id="@+id/etMazeretTarih"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="GG/AA/YYYY"
        android:inputType="date"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnMazeretKaydet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mazeret Kaydını İşle"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF" />

</LinearLayout>